function drawWing(c,wx,wy,s,flip){
  const W=WING_MAP[0].length;
  for(let r=0;r<WING_MAP.length;r++) for(let col=0;col<W;col++){
    if(!WING_MAP[r][col])continue;
    const ci=flip?(W-1-col):col;
    c.fillStyle=WING_INNER[r][col]?'#f0f8ff':(r<2?'#dce8ff':r<4?'#b8d0f8':'#8ab8f0');
    c.fillRect(wx+ci*s,wy+r*s,s,s);
  }
  for(let r=0;r<WING_MAP.length;r++) for(let col=0;col<W;col++){
    const ci=flip?(W-1-col):col,has=WING_MAP[r][col];
    const left=col>0?WING_MAP[r][col-1]:0,right=col<W-1?WING_MAP[r][col+1]:0;
    const up=r>0?WING_MAP[r-1][col]:0,dn=r<WING_MAP.length-1?WING_MAP[r+1][col]:0;
    if(has&&(!left||!right||!up||!dn)){c.fillStyle='rgba(40,60,120,0.45)';c.fillRect(wx+ci*s,wy+r*s,s,s);}
  }
}
function attachWings(c,cx,bodyTopY,s,frame){
  const wf=Math.sin(frame*.35),wLift=Math.round(wf*s*1.2);
