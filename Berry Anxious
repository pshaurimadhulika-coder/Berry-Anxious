/* ── STATE ── */
let anxiety=0,score=100,fruitIndex=0,questionIndex=0,dialogueStep=0;
let gamePhase='walking',timerInterval=null,timeLeft=0,maxTime=15,answered=false;
let strawberryFrame=0,frameTimer=0,fruitVisible=false,fruitX=960;
let gameAnimFrame=null,petalsInterval=null;
const GROUND_Y=540-88; // 452
let gCanvas,gCtx;

/* ── GAME LOOP ── */
function gameLoop(){
  if(gamePhase==='gameover')return;
  frameTimer++;if(frameTimer%7===0)strawberryFrame++;
  gCanvas=document.getElementById('gameCanvas');gCtx=gCanvas.getContext('2d');
  gCanvas.width=960;gCanvas.height=540;gCtx.clearRect(0,0,960,540);
  const c=gCtx;
  const spriteH=8*S,strawY=GROUND_Y-spriteH,strawX=100;
  drawStrawberry(c,strawX,strawY,strawberryFrame,S);
  if(fruitVisible&&fruitIndex<FRUITS.length){
    const fruitDrawY=GROUND_Y-9*S;
    drawFruitByIndex(c,FRUITS[fruitIndex].drawFn,fruitX,fruitDrawY,S,strawberryFrame);
    if(fruitX-strawX<220&&gamePhase==='walking')startDialogue();
  }
  if(gamePhase==='walking'&&fruitVisible)fruitX-=1.6;
  gameAnimFrame=requestAnimationFrame(gameLoop);
}

/* ── STAGE CANVAS ── */
let stageFrame=0,stageAnimId=null;
function startStageAnim(){stageFrame=0;if(stageAnimId)clearInterval(stageAnimId);stageAnimId=setInterval(()=>{stageFrame++;drawStageCharacters();},100);}
function stopStageAnim(){if(stageAnimId){clearInterval(stageAnimId);stageAnimId=null;}}
function drawStageCharacters(){
  const sc=document.getElementById('stageCanvas');if(!sc)return;
  const c=sc.getContext('2d');c.clearRect(0,0,960,220);
  const grad=c.createLinearGradient(0,0,0,220);
  grad.addColorStop(0,'#1e0a3c');grad.addColorStop(.6,'#4a1570');grad.addColorStop(1,'#7a2a7a');
  c.fillStyle=grad;c.fillRect(0,0,960,220);
  c.fillStyle='#5c2e7a';c.fillRect(0,190,960,30);c.fillStyle='#b06fcf';c.fillRect(0,190,960,3);
  if(fruitIndex<FRUITS.length)drawFruitByIndex(c,FRUITS[fruitIndex].drawFn,80,190-9*SS,SS,stageFrame);
  drawStrawberry(c,800,190-8*SS,stageFrame,SS);
}

/* ── TREES CANVAS ── */
function initTreesCanvas(){
  const tc=document.getElementById('treesCanvas');
  tc.width=3840;tc.height=452;
  const c=tc.getContext('2d');c.clearRect(0,0,3840,452);
  // Dense placement: one tree every ~130px across 4 screens
  const trees=[];
  for(let screen=0;screen<4;screen++)
    for(let i=0;i<8;i++)
      trees.push({x:screen*960+i*120+(i%2===0?0:20),t:i%2});
  for(const p of trees)drawTree(c,p.x,452,p.t);
}

function initTitleCanvas(){
  const c2=document.getElementById('titleCanvas').getContext('2d');
  const g=c2.createLinearGradient(0,0,0,540);
  g.addColorStop(0,'#1e0a3c');g.addColorStop(.3,'#4a1570');g.addColorStop(.55,'#8b3a8b');g.addColorStop(.75,'#e07840');g.addColorStop(1,'#f5c518');
  c2.fillStyle=g;c2.fillRect(0,0,960,540);
  // Trees on title screen
  for(let i=0;i<9;i++)drawTree(c2,i*110+(i%2===0?0:15),452,i%2);
  // Strawberry centre-right
  drawStrawberry(c2,430,452-8*S,2,S);
}

/* ── PETALS ── */
function spawnPetals(){
  const bg=document.getElementById('bgLayer');
  petalsInterval=setInterval(()=>{
    const p=document.createElement('div');p.className='petal';
    p.style.left=Math.random()*960+'px';p.style.top='-10px';
    p.style.animationDuration=(3+Math.random()*4)+'s';p.style.animationDelay=(Math.random()*2)+'s';
    p.style.background=['#ffb3d9','#ffd1ec','#ff9ec7','#ffe0f0'][Math.floor(Math.random()*4)];
    bg.appendChild(p);setTimeout(()=>p.remove(),8000);
  },280);
}

/* ── SCREENS ── */
function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}

function startGame(){
  showScreen('gameScreen');initTreesCanvas();spawnPetals();
  anxiety=0;score=100;fruitIndex=0;questionIndex=0;gamePhase='walking';fruitVisible=false;
  updateHUD();requestAnimationFrame(gameLoop);setTimeout(()=>spawnNextFruit(),1800);
}
function spawnNextFruit(){
  if(fruitIndex>=FRUITS.length){endGame();return;}
  fruitVisible=true;fruitX=1050;gamePhase='walking';
  document.getElementById('dialogueBox').style.display='none';
  document.getElementById('questionPanel').style.display='none';
}

/* ── DIALOGUE ── */
let dialogueLines=[],dialogueFruitName='';
function startDialogue(){
  if(gamePhase!=='walking')return;
  gamePhase='dialogue';fruitVisible=false;
  const fruit=FRUITS[fruitIndex];dialogueFruitName=fruit.name;
  dialogueLines=[fruit.intro,"Alright. Time for the questions."];dialogueStep=0;showDialogue();
}
function showDialogue(){
  document.getElementById('dialogueBox').style.display='block';
  document.getElementById('dialogueSpeaker').textContent=dialogueFruitName;
  document.getElementById('dialogueText').textContent=dialogueLines[dialogueStep];
}
function advanceDialogue(){
  dialogueStep++;
  if(dialogueStep>=dialogueLines.length){document.getElementById('dialogueBox').style.display='none';questionIndex=0;showQuestion();}
  else showDialogue();
}

/* ── QUESTIONS ── */
function showQuestion(){
  const fruit=FRUITS[fruitIndex];
  if(questionIndex>=fruit.questions.length){
    fruitIndex++;document.getElementById('fruitCounter').textContent=fruitIndex;stopStageAnim();
    document.getElementById('questionPanel').style.display='none';
    if(fruitIndex>=FRUITS.length)setTimeout(endGame,1000);
    else{gamePhase='walking';setTimeout(spawnNextFruit,2000);}
    return;
  }
  const q=fruit.questions[questionIndex];answered=false;
  document.getElementById('questionPanel').style.display='flex';
  document.getElementById('strawberryBubble').style.display='none';
  document.getElementById('fruitBubble').textContent=q.question.replace(/^[^']*'/,'').replace(/'\.?$/,'');
  startStageAnim();
  const grid=document.getElementById('answersGrid');grid.innerHTML='';
  q.answers.forEach((ans,i)=>{
    const btn=document.createElement('button');btn.className='answer-btn';
    btn.textContent=['A','B','C','D'][i]+') '+ans;
    btn.onclick=()=>handleAnswer(i,q.correct,btn,ans);grid.appendChild(btn);
  });
  document.getElementById('anxietyWarning').style.display='none';
  maxTime=q.time;timeLeft=maxTime;updateTimer();
  if(timerInterval)clearInterval(timerInterval);
  let tick=0;
  timerInterval=setInterval(()=>{
    timeLeft-=.1;tick++;updateTimer();
    const rate=.08+(fruitIndex*.025);
    if(timeLeft>0){
      anxiety=Math.min(100,anxiety+rate);updateHUD();
      if(tick%8===0){document.getElementById('anxietyWarning').style.display='block';setTimeout(()=>document.getElementById('anxietyWarning').style.display='none',400);}
    }
    if(timeLeft<=0){clearInterval(timerInterval);timeExpired(q.correct);}
  },100);
}
function updateTimer(){
  document.getElementById('timerFill').style.width=Math.max(0,(timeLeft/maxTime)*100)+'%';
  document.getElementById('timerSeconds').textContent=Math.ceil(timeLeft)+'s';
}
function handleAnswer(idx,correct,btn,answerText){
  if(answered)return;answered=true;clearInterval(timerInterval);
  document.getElementById('strawberryBubble').textContent=answerText;
  document.getElementById('strawberryBubble').style.display='block';
  document.querySelectorAll('.answer-btn')[correct].classList.add('correct');
  if(idx===correct){btn.classList.add('correct');anxiety=Math.max(0,anxiety*.55);updateHUD();setTimeout(()=>{questionIndex++;showQuestion();},1400);}
  else{btn.classList.add('wrong');anxiety=Math.min(100,anxiety+(20+fruitIndex*5));updateHUD();setTimeout(()=>{questionIndex++;showQuestion();},1600);}
}
function timeExpired(correct){
  if(answered)return;answered=true;
  const b=document.querySelectorAll('.answer-btn');if(b[correct])b[correct].classList.add('correct');
  document.getElementById('strawberryBubble').textContent='...';
  document.getElementById('strawberryBubble').style.display='block';
  anxiety=Math.min(100,anxiety+(25+fruitIndex*6));updateHUD();
  setTimeout(()=>{questionIndex++;showQuestion();},1600);
}
function updateHUD(){
  document.getElementById('anxietyFill').style.width=anxiety+'%';
  score=Math.max(0,Math.round(100-anxiety));
  document.getElementById('scoreDisplay').textContent=score;
}

/* ── END GAME ── */
function endGame(){
  clearInterval(timerInterval);clearInterval(petalsInterval);stopStageAnim();cancelAnimationFrame(gameAnimFrame);
  gamePhase='gameover';score=Math.max(0,Math.round(100-anxiety));
  let grade,msg;
  if(score>=90){grade='S RANK - THE SOCIAL BUTTERFLY';msg='Absolutely unshakeable. Every fruit walked away genuinely impressed. Gerald almost smiled. ALMOST.';}
  else if(score>=75){grade='A RANK - CONFIDENT BERRY';msg='You held it together when it mattered. A few nerves, but you pushed through every question with grace.';}
  else if(score>=55){grade='B RANK - HOLDING IT TOGETHER';msg='Gerald got to you a little. Beatrice definitely got to you. But you finished. That counts for a lot.';}
  else if(score>=35){grade='C RANK - ANXIOUS BUT ALIVE';msg='It was rough. The questions hit hard. But you answered every single one. That is not nothing.';}
  else{grade='D RANK - BERRY OVERWHELMED';msg='You showed up. You talked to five different fruits. Most berries never make it past Manny. Try again.';}
  showScreen('endScreen');
  document.getElementById('finalScore').textContent=score;
  document.getElementById('finalGrade').textContent=grade;
  document.getElementById('finalMsg').textContent=msg;
  const ec=document.getElementById('endCanvas').getContext('2d');
  for(let i=0;i<80;i++){ec.fillStyle=`hsl(${Math.random()*60+280},80%,${60+Math.random()*20}%)`;ec.beginPath();ec.arc(Math.random()*960,Math.random()*540,Math.random()*5+1,0,Math.PI*2);ec.fill();}
}
