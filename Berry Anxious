class SyrupDrop{
  constructor(cx,cy){
    const angle=Math.random()*Math.PI*2,spd=5+Math.random()*28;
    this.x=cx;this.y=cy;this.vx=Math.cos(angle)*spd;this.vy=Math.sin(angle)*spd-Math.random()*10;
    this.r=6+Math.random()*26;this.alpha=1;this.stuck=false;this.sp=0;
    this.grav=.4+Math.random()*.25;this.drag=.965+Math.random()*.02;
    this.trail=[];this.wob=Math.random()*Math.PI*2;
    const h=336+Math.random()*20,s=82+Math.random()*14,l=28+Math.random()*16;
    this.color=`hsl(${h},${s}%,${l}%)`;
  }
  update(){
    if(this.stuck){this.sp=Math.min(1,this.sp+.055);return;}
    this.trail.push({x:this.x,y:this.y,r:this.r*.4});
    if(this.trail.length>14)this.trail.shift();
    this.vy+=this.grav;this.vx*=this.drag;this.vy*=this.drag;
    this.x+=this.vx;this.y+=this.vy;
    if(this.x<-80||this.x>innerWidth+80||this.y>innerHeight+80)this.stuck=true;
  }
  draw(c){
    c.save();
    this.trail.forEach((t,i)=>{c.globalAlpha=(i/this.trail.length)*this.alpha*.4;c.fillStyle=this.color;c.beginPath();c.arc(t.x,t.y,t.r,0,Math.PI*2);c.fill();});
    c.globalAlpha=this.alpha;c.fillStyle=this.color;
    if(this.stuck){
      const sp=this.sp,pts=10;c.beginPath();
      for(let i=0;i<=pts;i++){const a=(i/pts)*Math.PI*2;const j=1+(Math.sin(a*5+this.wob)*.3+Math.cos(a*8+this.wob*.7)*.12);const r=this.r*(1+sp*1.7)*j;i===0?c.moveTo(this.x+Math.cos(a)*r,this.y+Math.sin(a)*r):c.lineTo(this.x+Math.cos(a)*r,this.y+Math.sin(a)*r);}
      c.closePath();c.fill();
      if(sp>.2&&this.y<innerHeight-10){
        const dl=sp*this.r*3.2;
        c.beginPath();c.arc(this.x,this.y+this.r+dl*.5,this.r*.42,0,Math.PI*2);c.fill();
        c.beginPath();c.moveTo(this.x-this.r*.3,this.y+this.r*.5);c.lineTo(this.x+this.r*.3,this.y+this.r*.5);c.lineTo(this.x+this.r*.24,this.y+this.r+dl);c.lineTo(this.x-this.r*.24,this.y+this.r+dl);c.closePath();c.fill();
      }
    }else{c.beginPath();c.arc(this.x,this.y,this.r,0,Math.PI*2);c.fill();}
    c.restore();
  }
}

let drops=[],splashRafId=null;
function launchSplash(cx,cy){
  drops=[];
  for(let i=0;i<110;i++)drops.push(new SyrupDrop(cx,cy));
  for(let i=0;i<22;i++){const d=new SyrupDrop(cx,cy);d.vy=Math.abs(d.vy)+3;d.r=20+Math.random()*38;drops.push(d);}
  cancelAnimationFrame(splashRafId);
  let coverStarted=false;
  function loop(){splashRafId=requestAnimationFrame(loop);sCtx.clearRect(0,0,innerWidth,innerHeight);drops.forEach(d=>{d.update();d.draw(sCtx);});if(!coverStarted&&drops.filter(d=>d.stuck).length>30){coverStarted=true;setTimeout(startCover,140);}}
  loop();
}
function startCover(){
  let t=0;
  function cl(){
    t+=.022;const alpha=Math.min(1,t);
    sCtx.clearRect(0,0,innerWidth,innerHeight);drops.forEach(d=>d.draw(sCtx));
    sCtx.save();sCtx.globalAlpha=alpha*.97;sCtx.fillStyle='#b0101e';sCtx.fillRect(0,0,innerWidth,innerHeight);sCtx.restore();
    if(alpha<1)requestAnimationFrame(cl);else{cancelAnimationFrame(splashRafId);revealGame();}
  }
  cl();
}

