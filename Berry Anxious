  c.fillStyle='#fff';c.fillRect(fx+s,fy+s,s,s);c.fillRect(fx+2*s,fy+s,s,s);
  c.fillStyle='#000';c.fillRect(fx+s,fy+s,s,s);c.fillRect(fx+2*s,fy+s,s,s);
  c.fillStyle='#3a0060';c.fillRect(fx+s,fy+2*s,s,s);c.fillRect(fx+Math.floor(s*1.5),fy+3*s,s,s);c.fillRect(fx+2*s,fy+2*s,s,s);
}
function drawFruitByIndex(c,idx,ox,oy,s,frame){
  frame=frame||0;
  switch(idx){case 0:drawPeach(c,ox,oy,s,frame);break;case 1:drawMango(c,ox,oy,s,frame);break;case 2:drawBlueberry(c,ox,oy,s,frame);break;case 3:drawPineapple(c,ox,oy,s,frame);break;case 4:drawGrapes(c,ox,oy,s,frame);break;}
}

/* ── TREES — tall enough so canopy covers ≥50% of 540px screen height ──
   Ground top = 452px from top (= 540-88).
   Trunk height = 140px  → trunk top at y=312.
   Canopy extends ~220px above trunk top → canopy top at y≈92.
   Total tree height ≈ 360px which is 360/540 = 67% of screen. ✓
   Canopy base anchored to trunk top + 12px overlap so they're visually joined. */
function drawTree(c,ox,oy,type){
  // oy = ground level (452)
  const trunkH=140, trunkW=24, trunkX=ox+50;
  const trunkTop=oy-trunkH; // 312

  // Branches — drawn before trunk so trunk overlaps
  c.fillStyle='#6a3a10';
  c.fillRect(trunkX-30,trunkTop+24,30,12);
  c.fillRect(trunkX+trunkW,trunkTop+34,30,12);
  c.fillRect(trunkX-2,trunkTop-16,10,36);
  c.fillRect(trunkX+16,trunkTop-12,10,40);

  // Trunk
  c.fillStyle='#7a4a1a';c.fillRect(trunkX,trunkTop,trunkW,trunkH);
  c.fillStyle='#5a3010';c.fillRect(trunkX+trunkW-6,trunkTop,6,trunkH);

  // Canopy base anchored just inside trunk top
  const canopyBaseY=trunkTop+14; // 326 → canopy draws upward from here
  const canopyOx=ox-8;

  if(type===0){
    // Pink blossom — large overlapping blobs rising ~220px above canopyBaseY
    const pinks=['#ff9ec7','#ff69b4','#ffb3d9','#e75480','#ffd1ec','#ff80b0'];
    const blobs=[
      {dx:18,dy:0,   w:80,h:70},{dx:44,dy:-36,w:95,h:88},
      {dx:6, dy:-28,w:78,h:82},{dx:74,dy:-22,w:76,h:74},
      {dx:30,dy:20,  w:86,h:62},{dx:-6,dy:-56,w:70,h:76},
      {dx:22,dy:-80,w:80,h:80},{dx:62,dy:-60,w:74,h:72},
      {dx:96,dy:-16,w:68,h:68},{dx:-14,dy:8, w:62,h:56},
      {dx:38,dy:-108,w:70,h:66},{dx:70,dy:-88,w:66,h:64},
      {dx:12,dy:-130,w:64,h:60},{dx:52,dy:-118,w:62,h:58},
    ];
    blobs.forEach((b,i)=>{
      const rx=b.w/2,ry=b.h/2;
      for(let py=0;py<b.h;py+=4) for(let px=0;px<b.w;px+=4){
        const nx=(px-rx)/rx,ny=(py-ry)/ry;
        if(nx*nx+ny*ny<1){c.fillStyle=pinks[(i+Math.floor(py/8)+Math.floor(px/8))%pinks.length];c.fillRect(canopyOx+b.dx+px,canopyBaseY+b.dy+py,4,4);}
      }
    });
    c.fillStyle='#fff8f8';
    for(let i=0;i<44;i++)c.fillRect(canopyOx+8+Math.floor(i*17)%150,canopyBaseY-50+Math.floor(i*11)%140,4,4);
  } else {
    // Purple autumn
    const purps=['#9b59b6','#7d3c98','#b06fcf','#4a235a','#d2a8f0','#6020a0'];
    const blobs=[
      {dx:18,dy:0,   w:78,h:68},{dx:44,dy:-34,w:92,h:86},
      {dx:6, dy:-26,w:76,h:80},{dx:72,dy:-20,w:74,h:72},
      {dx:28,dy:18,  w:84,h:60},{dx:-4,dy:-54,w:68,h:74},
      {dx:20,dy:-78,w:78,h:78},{dx:60,dy:-58,w:72,h:70},
      {dx:94,dy:-14,w:66,h:66},{dx:-12,dy:6, w:60,h:54},
      {dx:36,dy:-106,w:68,h:64},{dx:68,dy:-86,w:64,h:62},
      {dx:10,dy:-128,w:62,h:58},{dx:50,dy:-116,w:60,h:56},
    ];
    blobs.forEach((b,i)=>{
      const rx=b.w/2,ry=b.h/2;
      for(let py=0;py<b.h;py+=4) for(let px=0;px<b.w;px+=4){
        const nx=(px-rx)/rx,ny=(py-ry)/ry;
        if(nx*nx+ny*ny<1){c.fillStyle=purps[(i+Math.floor(py/8)+Math.floor(px/8))%purps.length];c.fillRect(canopyOx+b.dx+px,canopyBaseY+b.dy+py,4,4);}
      }
    });
  }
}

