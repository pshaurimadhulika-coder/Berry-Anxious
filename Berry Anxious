<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Berry Anxious</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;700;800;900&family=Press+Start+2P&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;overflow:hidden;font-family:'Baloo 2',cursive;cursor:none;}

/* ── CURSOR ── */
#cursor{position:fixed;width:16px;height:16px;background:#e8547a;border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .15s,height .15s;mix-blend-mode:multiply;}
#cursor.big{width:44px;height:44px;opacity:.4;}

/* ── INTRO SCENE ── */
#bg{position:fixed;inset:0;z-index:0;background:radial-gradient(ellipse at 55% 45%,#ffeef3 0%,#ffc8d8 45%,#ff9db5 100%);animation:bgPulse 5s ease-in-out infinite alternate;}
@keyframes bgPulse{
  0%{background:radial-gradient(ellipse at 40% 40%,#ffeef3 0%,#ffc8d8 45%,#ff9db5 100%);}
  50%{background:radial-gradient(ellipse at 65% 55%,#fff0f5 0%,#ffb8d0 40%,#ff85a8 100%);}
  100%{background:radial-gradient(ellipse at 50% 35%,#ffe8f0 0%,#ffd0e0 42%,#ff9ab8 100%);}}
#three-canvas{position:fixed;inset:0;z-index:2;}
#deco-layer{position:fixed;inset:0;z-index:1;pointer-events:none;overflow:hidden;}
.deco-berry{position:absolute;opacity:0;animation:decoFloat var(--dur) ease-in-out infinite alternate,decoFadeIn 1s var(--del) forwards;filter:drop-shadow(0 4px 10px rgba(180,40,70,.25));transform:rotate(var(--rot));}
@keyframes decoFadeIn{to{opacity:var(--op);}}
@keyframes decoFloat{0%{transform:translateY(0) rotate(var(--rot)) scale(1);}100%{transform:translateY(-38px) rotate(calc(var(--rot) + 15deg)) scale(1.10);}}
#hint{position:fixed;bottom:2.2rem;left:50%;transform:translateX(-50%);color:#e8547a;font-size:.9rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;opacity:.7;z-index:5;pointer-events:none;transition:opacity .4s;animation:hintPulse 2.8s ease-in-out infinite alternate;}
@keyframes hintPulse{0%{opacity:.35;transform:translateX(-50%) translateY(0);}100%{opacity:.75;transform:translateX(-50%) translateY(-5px);}}
#splash-canvas{position:fixed;inset:0;z-index:90;pointer-events:none;}

/* ── GAME WRAPPER — slides in after pop ── */
#gameWrapper{
  position:fixed;inset:0;z-index:95;
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity .55s ease;
  background:#0d0518;
  image-rendering:pixelated;image-rendering:crisp-edges;
}
#gameWrapper.visible{opacity:1;pointer-events:all;}

/* ── GAME CONTAINER ── */
#gameContainer{width:960px;height:540px;position:relative;overflow:hidden;image-rendering:pixelated;}
.screen{position:absolute;inset:0;display:none;align-items:center;justify-content:center;flex-direction:column;}
.screen.active{display:flex;}

/* TITLE */
#titleScreen{background:linear-gradient(180deg,#1e0a3c 0%,#4a1570 28%,#8b3a8b 52%,#e07840 74%,#f5c518 100%);}
#titleScreen h1{font-family:'Press Start 2P',monospace;font-size:34px;color:#fff;text-shadow:4px 4px 0 #8b0057,-2px -2px 0 #ff69b4;z-index:10;margin-bottom:8px;animation:titlePulse 2s ease-in-out infinite;}
#titleScreen .subtitle{font-family:'Press Start 2P',monospace;font-size:9px;color:#ffd1f0;margin-bottom:36px;z-index:10;text-shadow:2px 2px 0 #8b0057;}
@keyframes titlePulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
.start-btn{font-family:'Press Start 2P',monospace;font-size:13px;background:#ff4d8f;color:#fff;border:4px solid #fff;padding:14px 28px;cursor:pointer;z-index:10;box-shadow:6px 6px 0 #8b0057;transition:transform .1s,box-shadow .1s;}
.start-btn:hover{transform:translate(2px,2px);box-shadow:4px 4px 0 #8b0057;}
.start-btn:active{transform:translate(6px,6px);box-shadow:0 0 0 #8b0057;}

/* BG LAYER */
#bgLayer{position:absolute;inset:0;overflow:hidden;}
.sky{position:absolute;inset:0;background:linear-gradient(180deg,#1e0a3c 0%,#4a1570 28%,#8b3a8b 52%,#e07840 74%,#f5c518 100%);}
.petal{position:absolute;width:6px;height:4px;background:#ffb3d9;border-radius:50% 50% 50% 0;opacity:.8;animation:petalFall linear infinite;}
@keyframes petalFall{0%{transform:translateY(-20px) rotate(0deg);opacity:.8}100%{transform:translateY(560px) rotate(720deg);opacity:0}}

/* SEAMLESS GROUND */
#groundLayer{position:absolute;bottom:0;height:88px;width:400%;display:flex;animation:scrollGround 4s linear infinite;}
@keyframes scrollGround{0%{transform:translateX(0)}100%{transform:translateX(-25%)}}
.ground-segment{flex:0 0 25%;height:88px;background:repeating-linear-gradient(90deg,#5c2e7a 0,#5c2e7a 16px,#4a1f6a 16px,#4a1f6a 32px);border-top:4px solid #b06fcf;}

#gameCanvas{position:absolute;inset:0;width:100%;height:100%;}

/* HUD */
#hud{position:absolute;top:12px;left:0;width:100%;display:flex;align-items:center;justify-content:space-between;padding:0 16px;z-index:100;pointer-events:none;}
.anxiety-label{font-family:'Press Start 2P',monospace;font-size:7px;color:#ffd1f0;margin-bottom:4px;}
.anxiety-bar-wrap{width:220px;height:20px;border:3px solid #fff;background:#1a0a2e;box-shadow:3px 3px 0 #000;}
.anxiety-bar-fill{height:100%;background:linear-gradient(90deg,#44ff88,#ffee00,#ff4444);transition:width .2s;}
.hud-score{font-family:'Press Start 2P',monospace;font-size:9px;color:#fff;text-shadow:2px 2px 0 #000;}
.fruit-counter{font-family:'Press Start 2P',monospace;font-size:7px;color:#ffd1f0;}

/* DIALOGUE */
#dialogueBox{position:absolute;bottom:100px;left:50%;transform:translateX(-50%);width:700px;background:rgba(10,5,30,.97);border:4px solid #ff9ef5;padding:16px 20px;z-index:200;box-shadow:6px 6px 0 #8b0057;display:none;}
.dialogue-speaker{font-family:'Press Start 2P',monospace;font-size:8px;color:#ffcc00;margin-bottom:8px;}
.dialogue-text{font-family:'Press Start 2P',monospace;font-size:9px;color:#fff;line-height:1.7;}
.dialogue-continue{font-family:'Press Start 2P',monospace;font-size:7px;color:#ff9ef5;margin-top:10px;animation:blink 1s step-end infinite;cursor:pointer;}
@keyframes blink{50%{opacity:0}}

/* QUESTION PANEL */
#questionPanel{position:absolute;inset:0;background:rgba(8,3,22,.95);z-index:300;display:none;flex-direction:column;align-items:center;padding:0;}
#charStage{width:100%;height:220px;position:relative;background:linear-gradient(180deg,#1e0a3c 0%,#4a1570 60%,#8b3a8b 100%);border-bottom:3px solid #6a2090;flex-shrink:0;overflow:hidden;}
#stageCanvas{position:absolute;inset:0;width:100%;height:100%;}
.speech-bubble{position:absolute;background:#fff;border:3px solid #000;padding:8px 12px;font-family:'Press Start 2P',monospace;font-size:7px;color:#111;line-height:1.6;max-width:260px;z-index:10;min-width:60px;}
.speech-bubble::after{content:'';position:absolute;bottom:-12px;width:0;height:0;border-left:8px solid transparent;border-right:8px solid transparent;border-top:12px solid #000;}
.speech-bubble::before{content:'';position:absolute;bottom:-8px;width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:10px solid #fff;z-index:1;}
.speech-bubble.left::after{left:20px;}.speech-bubble.left::before{left:22px;}
.speech-bubble.right::after{right:20px;left:auto;}.speech-bubble.right::before{right:22px;left:auto;}
#fruitBubble{top:10px;left:60px;}
#strawberryBubble{top:10px;right:60px;background:#ffe8f5;border-color:#cc2266;display:none;}
#strawberryBubble::after{border-top-color:#cc2266;}#strawberryBubble::before{border-top-color:#ffe8f5;}
#questionBottom{width:100%;flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px 24px 6px;}
.timer-row{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.timer-label{font-family:'Press Start 2P',monospace;font-size:7px;color:#ccc;}
.timer-bar-wrap{width:340px;height:14px;border:3px solid #fff;background:#1a0a2e;box-shadow:3px 3px 0 #000;position:relative;}
.timer-bar-fill{height:100%;background:linear-gradient(90deg,#44ff88,#ffee00 60%,#ff4444);transition:width .08s linear;}
.timer-seconds{position:absolute;right:5px;top:50%;transform:translateY(-50%);font-family:'Press Start 2P',monospace;font-size:7px;color:#fff;}
.answers-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;width:720px;}
.answer-btn{font-family:'Press Start 2P',monospace;font-size:7px;background:#2d1b5e;color:#fff;border:3px solid #9060d0;padding:10px;cursor:pointer;text-align:left;line-height:1.6;box-shadow:4px 4px 0 #000;transition:background .15s,transform .1s;}
.answer-btn:hover{background:#4a2d8a;transform:translate(-2px,-2px);box-shadow:6px 6px 0 #000;}
.answer-btn.correct{background:#1a5c2e;border-color:#44ff88;pointer-events:none;}
.answer-btn.wrong{background:#5c1a1a;border-color:#ff4444;pointer-events:none;}
.answer-btn:disabled{pointer-events:none;}
.anxiety-warning{font-family:'Press Start 2P',monospace;font-size:8px;color:#ff4444;margin-top:4px;animation:blink .4s step-end infinite;display:none;}

/* END SCREEN */
#endScreen{background:linear-gradient(180deg,#1a0a2e 0%,#4a1570 50%,#8b3a8b 100%);gap:12px;}
#endScreen h2{font-family:'Press Start 2P',monospace;font-size:26px;color:#fff;text-shadow:4px 4px 0 #8b0057;}
.end-score-display{font-family:'Press Start 2P',monospace;font-size:56px;color:#ffcc00;text-shadow:4px 4px 0 #8b0000,-2px -2px 0 #ff9900;}
.end-grade{font-family:'Press Start 2P',monospace;font-size:12px;color:#ffd1f0;}
.end-msg{font-family:'Press Start 2P',monospace;font-size:8px;color:#ccc;max-width:600px;text-align:center;line-height:1.8;}
</style>
</head>
<body>

<!-- ════════════════════════════════════════
     INTRO — 3-D strawberry pop (unchanged)
════════════════════════════════════════ -->
<div id="cursor"></div>
<div id="bg"></div>
<div id="deco-layer"></div>
<canvas id="three-canvas"></canvas>
<canvas id="splash-canvas"></canvas>
<div id="hint">Scroll to spin &nbsp;·&nbsp; Click to pop</div>

<!-- ════════════════════════════════════════
     GAME — revealed after pop
════════════════════════════════════════ -->
<div id="gameWrapper">
  <div id="gameContainer">

    <!-- TITLE -->
    <div id="titleScreen" class="screen active">
      <canvas id="titleCanvas" width="960" height="540" style="position:absolute;inset:0;"></canvas>
      <h1>BERRY ANXIOUS</h1>
      <div class="subtitle">a game about social anxiety &amp; fruit</div>
      <button class="start-btn" onclick="startGame()">PLAY</button>
      <div style="position:absolute;bottom:0;width:100%;height:88px;background:repeating-linear-gradient(90deg,#5c2e7a 0,#5c2e7a 16px,#4a1f6a 16px,#4a1f6a 32px);border-top:4px solid #b06fcf;z-index:1;"></div>
    </div>

    <!-- GAME SCREEN -->
    <div id="gameScreen" class="screen">
      <div id="bgLayer"><div class="sky"></div></div>
      <!-- trees: 4× wide canvas scrolling seamlessly, bottom flush with ground top -->
      <canvas id="treesCanvas" width="3840" height="452"
        style="position:absolute;bottom:88px;left:0;width:400%;height:452px;animation:scrollGround 4s linear infinite;pointer-events:none;image-rendering:pixelated;"></canvas>
      <div id="groundLayer">
        <div class="ground-segment"></div><div class="ground-segment"></div>
        <div class="ground-segment"></div><div class="ground-segment"></div>
      </div>
      <canvas id="gameCanvas"></canvas>
      <div id="hud">
        <div>
          <div class="anxiety-label">ANXIETY</div>
          <div class="anxiety-bar-wrap"><div class="anxiety-bar-fill" id="anxietyFill" style="width:0%"></div></div>
        </div>
        <div class="hud-score">SCORE: <span id="scoreDisplay">100</span></div>
        <div class="fruit-counter">MET: <span id="fruitCounter">0</span>/5</div>
      </div>
      <div id="dialogueBox">
        <div class="dialogue-speaker" id="dialogueSpeaker"></div>
        <div class="dialogue-text" id="dialogueText"></div>
        <div class="dialogue-continue" onclick="advanceDialogue()">▼ press to continue</div>
      </div>
      <div id="questionPanel">
        <div id="charStage">
          <canvas id="stageCanvas" width="960" height="220"></canvas>
          <div class="speech-bubble left" id="fruitBubble"></div>
          <div class="speech-bubble right" id="strawberryBubble"></div>
        </div>
        <div id="questionBottom">
          <div class="timer-row">
            <span class="timer-label">TIME</span>
            <div class="timer-bar-wrap">
              <div class="timer-bar-fill" id="timerFill" style="width:100%"></div>
              <span class="timer-seconds" id="timerSeconds">15s</span>
            </div>
          </div>
          <div class="answers-grid" id="answersGrid"></div>
          <div class="anxiety-warning" id="anxietyWarning">⚠ ANXIETY RISING!</div>
        </div>
      </div>
    </div>

    <!-- END SCREEN -->
    <div id="endScreen" class="screen">
      <canvas id="endCanvas" width="960" height="540" style="position:absolute;inset:0;opacity:.3;"></canvas>
      <h2>GAME OVER</h2>
      <div style="font-family:'Press Start 2P',monospace;font-size:9px;color:#ffd1f0;">YOUR FINAL SCORE</div>
      <div class="end-score-display" id="finalScore">--</div>
      <div class="end-grade" id="finalGrade">--</div>
      <div class="end-msg" id="finalMsg"></div>
      <button class="start-btn" onclick="location.reload()" style="margin-top:16px;">PLAY AGAIN</button>
    </div>

  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
/* ════════════════════════════════════════════════════════════
   CURSOR
════════════════════════════════════════════════════════════ */
const cursorEl = document.getElementById('cursor');
let mx = innerWidth/2, my = innerHeight/2;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cursorEl.style.left = mx+'px'; cursorEl.style.top = my+'px';
});

/* ════════════════════════════════════════════════════════════
   DECO EMOJI BERRIES (identical to uploaded source)
════════════════════════════════════════════════════════════ */
const decoLayer = document.getElementById('deco-layer');
const decoItems = [];
const decoSizes=['1.0rem','2.2rem','1.5rem','2.8rem','1.2rem','2.0rem','1.4rem','2.5rem','1.1rem','1.8rem','2.4rem','1.3rem','2.0rem','1.6rem','2.6rem','1.2rem','1.9rem','2.3rem','1.4rem','2.1rem','1.7rem','2.5rem','1.1rem','2.0rem','1.5rem'];
let didx=0;
for(let drow=0;drow<5;drow++) for(let dcol=0;dcol<5;dcol++){
  const el=document.createElement('span'); el.className='deco-berry';
  const cellW=90/5, cellH=90/5;
  const x=5+dcol*cellW+cellW*.15+Math.random()*cellW*.7;
  const y=5+drow*cellH+cellH*.15+Math.random()*cellH*.7;
  const rot=Math.random()*360, dur=2.8+Math.random()*3.8;
  const op=0.18+Math.random()*.30, del=Math.random()*3.5;
  el.style.cssText=`left:${x}%;top:${y}%;font-size:${decoSizes[didx]};--rot:${rot}deg;--dur:${dur}s;--op:${op};--del:${del}s`;
  el.textContent='🍓';
  decoLayer.appendChild(el);
  decoItems.push({el,baseX:x,baseY:y});
  didx++;
}

/* ════════════════════════════════════════════════════════════
   THREE.JS SETUP (identical to uploaded source)
════════════════════════════════════════════════════════════ */
const canvas3=document.getElementById('three-canvas');
const renderer=new THREE.WebGLRenderer({canvas:canvas3,antialias:true,alpha:true});
renderer.setPixelRatio(Math.min(devicePixelRatio,2));
renderer.setSize(innerWidth,innerHeight);
renderer.physicallyCorrectLights=true;
renderer.toneMapping=THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure=1.1;
const scene=new THREE.Scene();
const camera=new THREE.PerspectiveCamera(38,innerWidth/innerHeight,.1,100);
camera.position.set(0,.1,6.5);
window.addEventListener('resize',()=>{camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();renderer.setSize(innerWidth,innerHeight);});

/* Lights */
const key=new THREE.DirectionalLight(0xffffff,2.2); key.position.set(0,10,3); scene.add(key);
const key2=new THREE.DirectionalLight(0xfff4f4,1.6); key2.position.set(-1,8,1); scene.add(key2);
const fill=new THREE.DirectionalLight(0xffe8ee,.8); fill.position.set(0,2,6); scene.add(fill);
const rim=new THREE.DirectionalLight(0xff7090,.25); rim.position.set(0,-4,-3); scene.add(rim);
scene.add(new THREE.AmbientLight(0xffd8e0,.9));
const hotspot=new THREE.PointLight(0xffffff,1.2,16); hotspot.position.set(0,3.5,3); scene.add(hotspot);

/* Berry group */
const berryGroup=new THREE.Group(); scene.add(berryGroup);

const profilePts=[
  new THREE.Vector2(0.01, 1.10),new THREE.Vector2(0.28, 1.06),new THREE.Vector2(0.60, 1.00),
  new THREE.Vector2(0.90, 0.80),new THREE.Vector2(1.04, 0.46),new THREE.Vector2(1.02, 0.08),
  new THREE.Vector2(0.96,-0.24),new THREE.Vector2(0.84,-0.52),new THREE.Vector2(0.68,-0.78),
  new THREE.Vector2(0.50,-0.98),new THREE.Vector2(0.34,-1.12),new THREE.Vector2(0.22,-1.22),
  new THREE.Vector2(0.13,-1.28),new THREE.Vector2(0.06,-1.30),new THREE.Vector2(0.01,-1.31),
];
const bodyGeo=new THREE.LatheGeometry(profilePts,128);
const tipCapGeo=new THREE.CircleGeometry(0.01,16);
const tipCapMesh=new THREE.Mesh(tipCapGeo,null);
tipCapMesh.rotation.x=Math.PI/2; tipCapMesh.position.y=-1.31;
berryGroup.add(tipCapMesh);

function buildBodyTexture(){
  const SZ=1024,cv=document.createElement('canvas');cv.width=SZ;cv.height=SZ;
  const g=cv.getContext('2d');
  g.fillStyle='#ff2d44';g.fillRect(0,0,SZ,SZ);
  const vGrad=g.createLinearGradient(0,0,0,SZ);
  vGrad.addColorStop(0,'rgba(255,160,160,0.35)');vGrad.addColorStop(.25,'rgba(255,100,100,0.12)');
  vGrad.addColorStop(.5,'rgba(0,0,0,0)');vGrad.addColorStop(1,'rgba(0,0,0,0.18)');
  g.fillStyle=vGrad;g.fillRect(0,0,SZ,SZ);
  const rows=[{v:.07,count:5,uOff:.00},{v:.13,count:6,uOff:.08},{v:.19,count:7,uOff:.03},{v:.25,count:8,uOff:.00},{v:.31,count:9,uOff:.06},{v:.37,count:9,uOff:.02},{v:.43,count:9,uOff:.05},{v:.49,count:8,uOff:.01},{v:.55,count:8,uOff:.07},{v:.61,count:7,uOff:.03},{v:.67,count:6,uOff:.09},{v:.73,count:5,uOff:.11},{v:.79,count:4,uOff:.12},{v:.84,count:3,uOff:.17},{v:.89,count:2,uOff:.25}];
  for(const row of rows){
    const py=row.v*SZ,bodyR=Math.sin(row.v*Math.PI)*.9+.1,dotR=Math.max(8,bodyR*12);
    for(let i=0;i<row.count;i++){
      const u=(row.uOff+i/row.count)%1.0,px=u*SZ;
      for(const ox of[0,SZ]){
        const x=px+ox;
        g.beginPath();g.arc(x,py,dotR*1.5,0,Math.PI*2);g.fillStyle='rgba(70,0,8,0.55)';g.fill();
        g.beginPath();g.arc(x,py,dotR*1.15,0,Math.PI*2);g.fillStyle='rgba(100,5,12,0.45)';g.fill();
        const sg=g.createRadialGradient(x-dotR*.3,py-dotR*.3,dotR*.04,x,py,dotR);
        sg.addColorStop(0,'#fffac0');sg.addColorStop(.30,'#f7d020');sg.addColorStop(.70,'#d09010');sg.addColorStop(1,'#906008');
        g.beginPath();g.arc(x,py,dotR*.82,0,Math.PI*2);g.fillStyle=sg;g.fill();
        g.beginPath();g.arc(x-dotR*.3,py-dotR*.3,dotR*.22,0,Math.PI*2);g.fillStyle='rgba(255,255,230,0.75)';g.fill();
      }
    }
  }
  const tex=new THREE.CanvasTexture(cv);tex.wrapS=THREE.RepeatWrapping;tex.wrapT=THREE.ClampToEdgeWrapping;return tex;
}
const bodyMat=new THREE.MeshPhongMaterial({color:new THREE.Color(0xffffff),specular:new THREE.Color(0xaa7777),shininess:28,map:buildBodyTexture()});
const bodyMesh=new THREE.Mesh(bodyGeo,bodyMat);
berryGroup.add(bodyMesh); tipCapMesh.material=bodyMat;

function makeLeaf(w,h){
  const shape=new THREE.Shape();shape.moveTo(0,0);
  shape.bezierCurveTo(w*.6,h*.1,w*.9,h*.55,0,h);
  shape.bezierCurveTo(-w*.9,h*.55,-w*.6,h*.1,0,0);
  return new THREE.ShapeGeometry(shape,16);
}
const leafMatA=new THREE.MeshPhongMaterial({color:new THREE.Color(0x4ec840),specular:new THREE.Color(0x88ee88),shininess:60,emissive:new THREE.Color(0x082008),emissiveIntensity:.08,side:THREE.DoubleSide});
const leafMatB=new THREE.MeshPhongMaterial({color:new THREE.Color(0x38aa28),specular:new THREE.Color(0x66cc66),shininess:50,emissive:new THREE.Color(0x051505),emissiveIntensity:.08,side:THREE.DoubleSide});
const leafDefs=[
  {ry:0,           rz:-1.25,w:.22,h:.48,mat:leafMatA},{ry:Math.PI*2/5,rz:-1.20,w:.18,h:.42,mat:leafMatB},
  {ry:Math.PI*4/5, rz:-1.22,w:.20,h:.46,mat:leafMatA},{ry:Math.PI*6/5,rz:-1.18,w:.18,h:.44,mat:leafMatB},
  {ry:Math.PI*8/5, rz:-1.24,w:.22,h:.48,mat:leafMatA},
];
for(const ld of leafDefs){
  const geo=makeLeaf(ld.w,ld.h),mesh=new THREE.Mesh(geo,ld.mat),pivot=new THREE.Group();
  pivot.rotation.y=ld.ry; mesh.rotation.z=ld.rz; mesh.position.y=1.10;
